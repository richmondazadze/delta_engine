# ============================================================
# Delta Engine — Environment Configuration Template
# Copy to .env and fill in your values
# ============================================================

# ---- Supabase ----
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# ---- FastAPI ----
API_HOST=0.0.0.0
API_PORT=8000
API_ENV=development
API_CORS_ORIGINS=http://localhost:3000,http://localhost:3001
API_DEBUG=true

# ---- Encryption ----
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# For AES-256-GCM: python -c "import secrets; print(secrets.token_hex(32))"
ENCRYPTION_KEY=your-256-bit-hex-key-here

# ---- Stripe ----
STRIPE_SECRET_KEY=sk_test_your-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
STRIPE_PRICE_STARTER=price_starter_id
STRIPE_PRICE_PRO=price_pro_id
STRIPE_PRICE_SCALE=price_scale_id
STRIPE_PRICE_ELITE=price_elite_id

# ---- Dashboard ----
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_API_URL=http://localhost:8000

# ---- Worker ----
WORKER_NAME=worker-local-01
WORKER_REGION=local
WORKER_CAPACITY=5
WORKER_HEARTBEAT_INTERVAL_SECONDS=30
WORKER_POLL_INTERVAL_MS=500

# ---- Internal worker API (service key for workers calling FastAPI) ----
WORKER_API_KEY=generate-a-long-random-secret-here

# ---- Phase 2 worker ↔ API ----
DELTA_CONFIG_SOURCE=yaml
API_URL=http://localhost:8000
WORKER_USER_ID=
WORKER_DEV_EMAIL=dev@deltaengine.local
WORKER_DEV_PASSWORD=dev-password-change-me
