# Worker-local overrides (optional)
WORKER_POLL_INTERVAL_MS=50
WORKER_POLL_FALLBACK_MS=1000
WORKER_SIGNAL_BUS_ENABLED=0
# WORKER_SIGNAL_BUS_DIR=C:\Users\YOU\AppData\Roaming\MetaQuotes\Terminal\Common\Files\delta_engine
WORKER_POOL_WARM_TTL_SECONDS=60
WORKER_POOL_OPTIMISTIC_WARM=1
WORKER_ALWAYS_ISOLATE_MASTERS=0
WORKER_PARALLEL_TERMINALS=1
# Remote API timeouts (Render cold start may need 60–90s on first request)
# WORKER_API_READ_TIMEOUT_SECONDS=90
# WORKER_API_CONNECT_TIMEOUT_SECONDS=15
# WORKER_API_RETRY_ATTEMPTS=4
# WORKER_STARTUP_API_ATTEMPTS=3
# Force one subprocess per follower even when terminal_path is shared (not recommended on Windows)
# WORKER_DEDICATED_POOL_PER_ACCOUNT=0
WORKER_MASTER_STATUS_INTERVAL_SECONDS=30
WORKER_COMMAND_POLL_SECONDS=2
WORKER_LOCAL_LOG=0
WORKER_EVENT_FLUSH_SECONDS=0.15
SOAK_HOURS=24
