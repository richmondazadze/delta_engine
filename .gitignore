# ============================================================
# CopyMorphic / Delta Engine — do not commit secrets or local runtime
# ============================================================

# ---- Environment & secrets ----
.env
.env.*
!.env.example
!**/.env.example
*.pem
*.key
*.p12
credentials.json
secrets.json

# Frontend env (never commit — use .env.local.example as template)
frontend/.env.local
frontend/.env.development.local
frontend/.env.production.local
frontend/.env.test.local

# Worker env overrides
worker/.env

# ---- Worker local config (use *.example.yaml templates) ----
worker/config/accounts.yaml
worker/config/copiers.yaml
worker/config/symbol_map.yaml

# Worker runtime output
worker/logs/*
!worker/logs/.gitkeep
*.jsonl

# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
.venv/
env/
backend/venv/
worker/venv/
*.egg-info/
.eggs/
dist/
build/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/
.tox/
*.cover

# ---- Node / Next.js ----
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/.turbo/
frontend/.vercel/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.tsbuildinfo

# ---- IDE & editor ----
.idea/
.vscode/
*.swp
*.swo
*~
.project
.classpath
.settings/

# ---- OS ----
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db
*.lnk

# ---- Logs ----
*.log
# (worker logs: see worker/logs/* above)

# ---- Deploy / tooling ----
.vercel/
.stripe/
*.local

# ---- OneDrive / sync conflict junk ----
.~lock.*
* conflict*
*.tmp

# ---- Optional local overrides (uncomment if you use these) ----
# .cursor/
# .agents/
